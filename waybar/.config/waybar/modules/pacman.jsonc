{
  "custom/pacman": {
    "format": "  {}",
    "interval": 60,
    "exec": "cat /tmp/pacman-updates 2> /dev/null || echo '0'",
    "on-click": "kitty --hold sh -c 'yay -Syu; pkill -RTMIN+8 waybar; ~/.config/waybar/scripts/update-check.sh'",
    "on-click-right": "$HOME/.config/waybar/scripts/update-check.sh; pkill -RTMIN+8 waybar",
    "signal": 8,
    "tooltip-format": "{} updates available\n(right-click to refresh)"
  }
}
